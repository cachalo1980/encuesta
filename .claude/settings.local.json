{
  "permissions": {
    "allow": [
      "Bash(docker compose:*)",
      "Bash(curl -s http://localhost:8001/health)",
      "Bash(curl -s http://localhost:8001/db-check)",
      "Bash(curl -s -X POST http://localhost:8001/users/ -H \"Content-Type: application/json\" -d '{\"name\": \"Manuel Rodriguez\", \"email\": \"radamanuelrod@gmail.com\"}')",
      "Bash(curl -s http://localhost:8001/questions/)",
      "Bash(python3 -m json.tool)",
      "Bash(curl -s -o /dev/null -w \"HTTP Status: %{http_code}\\\\n\" -X POST http://localhost:8001/users/ -H \"Content-Type: application/json\" -d '{\"name\": \"Manuel Rodriguez\", \"email\": \"radamanuelrod@gmail.com\"}')",
      "Bash(curl -s http://localhost:8001/users/)",
      "Bash(DOCKER_BUILDKIT=0 docker compose up --build -d)",
      "Bash(docker build:*)",
      "Bash(cp ~/.docker/config.json ~/.docker/config.json.bak)",
      "Bash(python3 -c ':*)",
      "Bash(curl -s -X POST \"http://localhost:8001/users/1/responses/\" -H \"Content-Type: application/json\" -d '[{\"question_id\": 1, \"text_answer\": \"25 años\"}, {\"question_id\": 12, \"scale_answer\": 7}]')",
      "Bash(curl -s http://localhost:8001/users/1/responses/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8001/health)"
    ]
  }
}
